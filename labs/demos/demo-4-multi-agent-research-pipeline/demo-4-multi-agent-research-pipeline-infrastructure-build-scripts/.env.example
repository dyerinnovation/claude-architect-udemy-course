# Copy to .env and fill in your key, then: export $(grep -v '^#' .env | xargs)
ANTHROPIC_API_KEY=sk-ant-replace-me

# Model used by both coordinator and subagents. Override to a smaller model for cheaper demo runs.
CLAUDE_MODEL=claude-sonnet-4-5-20250929

# Number of parallel subagents the coordinator will spawn per run. Demo default is 3.
SUBAGENT_COUNT=3

# Max coordinator-loop iterations before forced synthesis (stop_reason safety net).
MAX_COORDINATOR_STEPS=6

# Where the pipeline writes per-run reports and per-subagent handoffs.
OUTPUT_DIR=./research-output
